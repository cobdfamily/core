{
  "compilerOptions": {
    "target": "es6",
    "module": "commonjs",
    "lib": ["es6","dom"],
    "allowJs": true,
"declaration": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
"exclude": ["./dist", "./tests", "./jest.config.js"]
}
